@DefaultFileDropdownBoxStyle = FileDropdownBoxStyle(
  DefaultBackground: (TexturePath: "../Textures/MedievalShop/Patches/Dropdown.png", Border: 16),
  HoveredBackground: (TexturePath: "../Textures/MedievalShop/Patches/DropdownHovered.png", Border: 16),
  PressedBackground: (TexturePath: "../Textures/MedievalShop/Patches/DropdownPressed.png", Border: 16),
  DefaultArrowTexturePath: "../Textures/MedievalShop/Patches/DropdownCaret.png",
  HoveredArrowTexturePath: "../Textures/MedievalShop/Patches/DropdownCaret.png",
