$Sounds = "Sounds.ui";

// Medieval color palette — parchment cream, aged gold, leather brown, hammered iron
@ColorDefault = #f5e8c8;             // Parchment cream (light text)
@ColorDefaultLabel = #c9b181;        // Faded ink on parchment (default labels)
@ColorBlueAccent = #d4a849;          // Aged gold (primary accent — replaces blue)
@ColorBlueAccentHovered = #f0c468;   // Bright gold (hover)
@ColorBlueAccentPressed = #a07a2c;   // Dark gold (pressed)
@ColorGoldHighlight = #e8a93b;       // Highlight gold (kept — already medieval)
@ColorGrayCaption = #9c8463;         // Aged leather caption
@ColorCaptionLight = #6e5839;        // Dark leather caption
@ColorButtonText = #f1ddb0;          // Warm parchment text on buttons
@ColorDisabled = #6e5839;            // Faded leather (disabled)
@ColorPlaceholder = #8c7350;         // Sepia placeholder
@ColorCodeText = #d8c89c;            // Old-paper monospace

// Background Colors
@ColorBackgroundCode = #1a120a;      // Deep wood/sepia
@ColorSimpleButtonBackground = #1a120a(0.4);


// Panels
@Panel = Group {
  Background: (TexturePath: "../Textures/MedievalShop/Patches/ContainerFullPatch.png", Border: 20);
};

@TitleLabel = Label {
  Style: (FontSize: 40, Alignment: Center);
};

@DefaultLabelStyle = (FontSize: 16, TextColor: #c9b181);

// Buttons
@ButtonSounds = $Sounds.@ButtonsLight;
@ButtonsCancel = $Sounds.@ButtonsCancel;
@ButtonDestructiveSounds = $Sounds.@ButtonsDestructive;

@ButtonBorder = 12;
@PrimaryButtonHeight = 44;
@SmallButtonHeight = 32;
@BigButtonHeight = 48;
@ButtonPadding = 24;
@DefaultButtonMinWidth = 172;

// Legacy aliases for backward compatibility
@DefaultButtonHeight = @PrimaryButtonHeight;
@DefaultButtonPadding = @ButtonPadding;

@DefaultButtonDefaultBackground = PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/Buttons/Primary.png", VerticalBorder: @ButtonBorder, HorizontalBorder: 80);
@DefaultButtonHoveredBackground = PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/Buttons/Primary_Hovered.png", VerticalBorder: @ButtonBorder, HorizontalBorder: 80);
@DefaultButtonPressedBackground = PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/Buttons/Primary_Pressed.png", VerticalBorder: @ButtonBorder, HorizontalBorder: 80);
@DefaultButtonDisabledBackground = PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/Buttons/Disabled.png", VerticalBorder: @ButtonBorder, HorizontalBorder: 80);

@DefaultSquareButtonDefaultBackground = PatchStyle(TexturePath: "../Common/Buttons/Primary_Square.png", Border: @ButtonBorder);
@DefaultSquareButtonHoveredBackground = PatchStyle(TexturePath: "../Common/Buttons/Primary_Square_Hovered.png", Border: @ButtonBorder);
@DefaultSquareButtonPressedBackground = PatchStyle(TexturePath: "../Common/Buttons/Primary_Square_Pressed.png", Border: @ButtonBorder);
@DefaultSquareButtonDisabledBackground = PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/Buttons/Disabled.png", Border: @ButtonBorder);

@TertiaryDefaultButtonBackground = PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/Buttons/Tertiary.png", Border: @ButtonBorder);
@TertiaryHoveredButtonBackground = PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/Buttons/Tertiary_Hovered.png", Border: @ButtonBorder);
@TertiaryPressedButtonBackground = PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/Buttons/Tertiary_Pressed.png", Border: @ButtonBorder);
@TertiaryDisabledButtonBackground = PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/Buttons/Disabled.png", Border: @ButtonBorder);
@TertiaryActiveButtonBackground = PatchStyle(TexturePath: "../Common/Buttons/Tertiary_Active.png", Border: @ButtonBorder);

@DefaultButtonLabelStyle = LabelStyle(
  FontSize: 17,
  TextColor: @ColorButtonText,
  RenderBold: true,
  RenderUppercase: true,
  HorizontalAlignment: Center,
  ShrinkTextToFit: true,
  MinShrinkTextToFitFontSize: 12,
  VerticalAlignment: Center
);

@DefaultButtonDisabledLabelStyle = LabelStyle(
  ...@DefaultButtonLabelStyle,
  TextColor: @ColorDisabled
);

// Client-compatible aliases
@PrimaryButtonLabelStyle = @DefaultButtonLabelStyle;
@PrimaryButtonDisabledLabelStyle = @DefaultButtonDisabledLabelStyle;

@SecondaryButtonLabelStyle = LabelStyle(
  ...@DefaultButtonLabelStyle,
  TextColor: #e9d4a4
);

@SecondaryButtonDisabledLabelStyle = LabelStyle(
  ...@SecondaryButtonLabelStyle,
  TextColor: @ColorDisabled
);

@SmallButtonLabelStyle = LabelStyle(
  ...@DefaultButtonLabelStyle,
  FontSize: 14
);

@SmallButtonDisabledLabelStyle = LabelStyle(
  ...@SmallButtonLabelStyle,
  TextColor: @ColorDisabled
);

@SmallSecondaryButtonLabelStyle = LabelStyle(
  ...@SecondaryButtonLabelStyle,
  FontSize: 14
);

@SmallSecondaryButtonDisabledLabelStyle = LabelStyle(
  ...@SmallSecondaryButtonLabelStyle,
  TextColor: @ColorDisabled
);

@DefaultButtonStyle = ButtonStyle(
  Default: (Background: @DefaultSquareButtonDefaultBackground),
  Hovered: (Background: @DefaultSquareButtonHoveredBackground),
  Pressed: (Background: @DefaultSquareButtonPressedBackground),
  Disabled: (Background: @DefaultSquareButtonDisabledBackground),
  Sounds: @ButtonSounds,
);

@DefaultTextButtonStyle = TextButtonStyle(
  Default: (Background: @DefaultButtonDefaultBackground, LabelStyle: @DefaultButtonLabelStyle),
  Hovered: (Background: @DefaultButtonHoveredBackground, LabelStyle: @DefaultButtonLabelStyle),
  Pressed: (Background: @DefaultButtonPressedBackground, LabelStyle: @DefaultButtonLabelStyle),
  Disabled: (Background: @DefaultButtonDisabledBackground, LabelStyle: @DefaultButtonDisabledLabelStyle),
  Sounds: @ButtonSounds,
);

@SmallDefaultTextButtonStyle = TextButtonStyle(
  Default: (Background: (TexturePath: "../Common/ButtonSmall.png", Border: 6), LabelStyle: @SmallButtonLabelStyle),
  Hovered: (Background: (TexturePath: "../Common/ButtonSmallHovered.png", Border: 6), LabelStyle: @SmallButtonLabelStyle),
  Pressed: (Background: (TexturePath: "../Common/ButtonSmallPressed.png", Border: 6), LabelStyle: @SmallButtonLabelStyle),
  Disabled: (Background: @DefaultButtonDisabledBackground, LabelStyle: @SmallButtonDisabledLabelStyle),
  Sounds: @ButtonSounds,
);

@CancelTextButtonStyle = TextButtonStyle(
  Default: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/Buttons/Destructive.png", Border: @ButtonBorder), LabelStyle: @DefaultButtonLabelStyle),
  Hovered: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/Buttons/Destructive_Hovered.png", Border: @ButtonBorder), LabelStyle: @DefaultButtonLabelStyle),
  Pressed: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/Buttons/Destructive_Pressed.png", Border: @ButtonBorder), LabelStyle: @DefaultButtonLabelStyle),
  Disabled: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/Buttons/Disabled.png", Border: @ButtonBorder), LabelStyle: @DefaultButtonDisabledLabelStyle),
  Sounds: @ButtonsCancel,
);

@CancelButtonStyle = ButtonStyle(
  Default: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/Buttons/Destructive.png", Border: @ButtonBorder)),
  Hovered: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/Buttons/Destructive_Hovered.png", Border: @ButtonBorder)),
  Pressed: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/Buttons/Destructive_Pressed.png", Border: @ButtonBorder)),
  Disabled: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/Buttons/Disabled.png", Border: @ButtonBorder)),
  Sounds: @ButtonSounds,
);

@SecondaryButtonStyle = ButtonStyle(
  Default: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/Buttons/Secondary.png", Border: @ButtonBorder)),
  Hovered: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/Buttons/Secondary_Hovered.png", Border: @ButtonBorder)),
  Pressed: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/Buttons/Secondary_Pressed.png", Border: @ButtonBorder)),
  Disabled: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/Buttons/Disabled.png", Border: @ButtonBorder)),
  Sounds: @ButtonSounds,
);

@SecondaryTextButtonStyle = TextButtonStyle(
  Default: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/Buttons/Secondary.png", Border: @ButtonBorder), LabelStyle: @SecondaryButtonLabelStyle),
  Hovered: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/Buttons/Secondary_Hovered.png", Border: @ButtonBorder), LabelStyle: @SecondaryButtonLabelStyle),
  Pressed: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/Buttons/Secondary_Pressed.png", Border: @ButtonBorder), LabelStyle: @SecondaryButtonLabelStyle),
  Disabled: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/Buttons/Disabled.png", Border: @ButtonBorder), LabelStyle: @DefaultButtonDisabledLabelStyle)
);

@TertiaryButtonStyle = ButtonStyle(
  Default: (Background: @TertiaryDefaultButtonBackground),
  Hovered: (Background: @TertiaryHoveredButtonBackground),
  Pressed: (Background: @TertiaryPressedButtonBackground),
  Disabled: (Background: @TertiaryDisabledButtonBackground),
  Sounds: @ButtonSounds,
);

@SmallSecondaryTextButtonStyle = TextButtonStyle(
  Default: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/Buttons/Secondary.png", Border: @ButtonBorder), LabelStyle: @SmallSecondaryButtonLabelStyle),
  Hovered: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/Buttons/Secondary_Hovered.png", Border: @ButtonBorder), LabelStyle: @SmallSecondaryButtonLabelStyle),
  Pressed: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/Buttons/Secondary_Pressed.png", Border: @ButtonBorder), LabelStyle: @SmallSecondaryButtonLabelStyle),
  Disabled: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/Buttons/Disabled.png", Border: @ButtonBorder), LabelStyle: @SmallButtonDisabledLabelStyle)
);

@TertiaryTextButtonStyle = TextButtonStyle(
  Default: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/Buttons/Tertiary.png", Border: @ButtonBorder), LabelStyle: @SecondaryButtonLabelStyle),
  Hovered: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/Buttons/Tertiary_Hovered.png", Border: @ButtonBorder), LabelStyle: @SecondaryButtonLabelStyle),
  Pressed: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/Buttons/Tertiary_Pressed.png", Border: @ButtonBorder), LabelStyle: @SecondaryButtonLabelStyle),
  Disabled: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/Buttons/Disabled.png", Border: @ButtonBorder), LabelStyle: @DefaultButtonDisabledLabelStyle)
);

@SmallTertiaryTextButtonStyle = TextButtonStyle(
  Default: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/Buttons/Tertiary.png", Border: @ButtonBorder), LabelStyle: @SmallSecondaryButtonLabelStyle),
  Hovered: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/Buttons/Tertiary_Hovered.png", Border: @ButtonBorder), LabelStyle: @SmallSecondaryButtonLabelStyle),
  Pressed: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/Buttons/Tertiary_Pressed.png", Border: @ButtonBorder), LabelStyle: @SmallSecondaryButtonLabelStyle),
  Disabled: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/Buttons/Disabled.png", Border: @ButtonBorder), LabelStyle: @SmallButtonDisabledLabelStyle)
);

@TextButton = TextButton {
  @Anchor = Anchor();
  @Sounds = ();
  @Text = "";
  Style: (
    ...@DefaultTextButtonStyle,
    Sounds: (
      ...$Sounds.@ButtonsLight,
      ...@Sounds
    )
  );
  Anchor: (...@Anchor, Height: @DefaultButtonHeight);
  Padding: (Horizontal: @DefaultButtonPadding);
  Text: @Text;
};

@Button = Button {
  @Anchor = Anchor();
  @Sounds = ();
  Style: (
    ...@DefaultButtonStyle,
    Sounds: (
      ...$Sounds.@ButtonsLight,
      ...@Sounds
    )
  );
  Anchor: (...@Anchor, Height: @DefaultButtonHeight, Width: @DefaultButtonHeight);
  Padding: (Horizontal: @DefaultButtonPadding);
};

@CancelTextButton = TextButton {
  @Anchor = Anchor();
  @Sounds = ();
  @Text = "";
  Style: (
    ...@CancelTextButtonStyle,
    Sounds: (
      ...$Sounds.@ButtonsCancel,
      ...@Sounds
    )
  );
  Anchor: (...@Anchor, Height: @DefaultButtonHeight);
  Padding: (Horizontal: @DefaultButtonPadding);
  Text: @Text;
};

@CancelButton = Button {
  @Anchor = Anchor();
  @Sounds = ();
  @Width = @DefaultButtonHeight;
  Style: (
    ...@CancelButtonStyle,
    Sounds: (
      ...$Sounds.@ButtonsLight,
      ...@Sounds
    )
  );
  Anchor: (...@Anchor, Height: @DefaultButtonHeight, Width: @Width);
};

@SmallSecondaryTextButton = TextButton {
  @Anchor = Anchor();
  @Sounds = ();
  @Text = "";
  Style: (
    ...@SmallSecondaryTextButtonStyle,
    Sounds: (
      ...$Sounds.@ButtonsLight,
      ...@Sounds
    )
  );
  Anchor: (...@Anchor, Height: @SmallButtonHeight);
  Padding: (Horizontal: 16);
  Text: @Text;
};

@SmallPrimaryTextButtonStyle = TextButtonStyle(
  Default: (Background: @DefaultButtonDefaultBackground, LabelStyle: @SmallButtonLabelStyle),
  Hovered: (Background: @DefaultButtonHoveredBackground, LabelStyle: @SmallButtonLabelStyle),
  Pressed: (Background: @DefaultButtonPressedBackground, LabelStyle: @SmallButtonLabelStyle),
  Disabled: (Background: @DefaultButtonDisabledBackground, LabelStyle: @SmallButtonDisabledLabelStyle),
  Sounds: @ButtonSounds,
);

@SmallTextButton = TextButton {
  @Anchor = Anchor();
  @Sounds = ();
  @Text = "";
  Style: (
    ...@SmallPrimaryTextButtonStyle,
    Sounds: (
      ...$Sounds.@ButtonsLight,
      ...@Sounds
    )
  );
  Anchor: (...@Anchor, Height: @SmallButtonHeight);
  Padding: (Horizontal: 16);
  Text: @Text;
};

@SmallCancelTextButtonStyle = TextButtonStyle(
  Default: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/Buttons/Destructive.png", Border: @ButtonBorder), LabelStyle: @SmallButtonLabelStyle),
  Hovered: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/Buttons/Destructive_Hovered.png", Border: @ButtonBorder), LabelStyle: @SmallButtonLabelStyle),
  Pressed: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/Buttons/Destructive_Pressed.png", Border: @ButtonBorder), LabelStyle: @SmallButtonLabelStyle),
  Disabled: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/Buttons/Disabled.png", Border: @ButtonBorder), LabelStyle: @SmallButtonDisabledLabelStyle),
  Sounds: @ButtonsCancel,
);

@SmallCancelTextButton = TextButton {
  @Anchor = Anchor();
  @Sounds = ();
  @Text = "";
  Style: (
    ...@SmallCancelTextButtonStyle,
    Sounds: (
      ...$Sounds.@ButtonsCancel,
      ...@Sounds
    )
  );
  Anchor: (...@Anchor, Height: @SmallButtonHeight);
  Padding: (Horizontal: 16);
  Text: @Text;
};

@SellTextButtonStyle = TextButtonStyle(
  Default: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/SellButton/Sell.png", VerticalBorder: @ButtonBorder, HorizontalBorder: 40), LabelStyle: @DefaultButtonLabelStyle),
  Hovered: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/SellButton/Sell_Hovered.png", VerticalBorder: @ButtonBorder, HorizontalBorder: 40), LabelStyle: @DefaultButtonLabelStyle),
  Pressed: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/SellButton/Sell_Pressed.png", VerticalBorder: @ButtonBorder, HorizontalBorder: 40), LabelStyle: @DefaultButtonLabelStyle),
  Disabled: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/Buttons/Disabled.png", VerticalBorder: @ButtonBorder, HorizontalBorder: 80), LabelStyle: @DefaultButtonDisabledLabelStyle),
  Sounds: @ButtonSounds,
);

@SellTextButton = TextButton {
  @Anchor = Anchor();
  @Sounds = ();
  @Text = "";
  Style: (
    ...@SellTextButtonStyle,
    Sounds: (
      ...$Sounds.@ButtonsLight,
      ...@Sounds
    )
  );
  Anchor: (...@Anchor, Height: @DefaultButtonHeight);
  Padding: (Horizontal: @DefaultButtonPadding);
  Text: @Text;
};

@SmallSellTextButtonStyle = TextButtonStyle(
  Default: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/SellButton/Sell.png", VerticalBorder: @ButtonBorder, HorizontalBorder: 40), LabelStyle: @SmallButtonLabelStyle),
  Hovered: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/SellButton/Sell_Hovered.png", VerticalBorder: @ButtonBorder, HorizontalBorder: 40), LabelStyle: @SmallButtonLabelStyle),
  Pressed: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/SellButton/Sell_Pressed.png", VerticalBorder: @ButtonBorder, HorizontalBorder: 40), LabelStyle: @SmallButtonLabelStyle),
  Disabled: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/Buttons/Disabled.png", VerticalBorder: @ButtonBorder, HorizontalBorder: 80), LabelStyle: @SmallButtonDisabledLabelStyle),
  Sounds: @ButtonSounds,
);

@SmallSellTextButton = TextButton {
  @Anchor = Anchor();
  @Sounds = ();
  @Text = "";
  Style: (
    ...@SmallSellTextButtonStyle,
    Sounds: (
      ...$Sounds.@ButtonsLight,
      ...@Sounds
    )
  );
  Anchor: (...@Anchor, Height: @SmallButtonHeight);
  Padding: (Horizontal: 16);
  Text: @Text;
};

@BuyTextButtonStyle = TextButtonStyle(
  Default: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/BuyButton/Buy.png", VerticalBorder: @ButtonBorder, HorizontalBorder: 40), LabelStyle: @DefaultButtonLabelStyle),
  Hovered: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/BuyButton/Buy_Hovered.png", VerticalBorder: @ButtonBorder, HorizontalBorder: 40), LabelStyle: @DefaultButtonLabelStyle),
  Pressed: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/BuyButton/Buy_Pressed.png", VerticalBorder: @ButtonBorder, HorizontalBorder: 40), LabelStyle: @DefaultButtonLabelStyle),
  Disabled: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/Buttons/Disabled.png", VerticalBorder: @ButtonBorder, HorizontalBorder: 80), LabelStyle: @DefaultButtonDisabledLabelStyle),
  Sounds: @ButtonSounds,
);

@BuyTextButton = TextButton {
  @Anchor = Anchor();
  @Sounds = ();
  @Text = "";
  Style: (
    ...@BuyTextButtonStyle,
    Sounds: (
      ...$Sounds.@ButtonsLight,
      ...@Sounds
    )
  );
  Anchor: (...@Anchor, Height: @DefaultButtonHeight);
  Padding: (Horizontal: @DefaultButtonPadding);
  Text: @Text;
};

@SmallBuyTextButtonStyle = TextButtonStyle(
  Default: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/BuyButton/Buy.png", VerticalBorder: @ButtonBorder, HorizontalBorder: 40), LabelStyle: @SmallButtonLabelStyle),
  Hovered: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/BuyButton/Buy_Hovered.png", VerticalBorder: @ButtonBorder, HorizontalBorder: 40), LabelStyle: @SmallButtonLabelStyle),
  Pressed: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/BuyButton/Buy_Pressed.png", VerticalBorder: @ButtonBorder, HorizontalBorder: 40), LabelStyle: @SmallButtonLabelStyle),
  Disabled: (Background: PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/Buttons/Disabled.png", VerticalBorder: @ButtonBorder, HorizontalBorder: 80), LabelStyle: @SmallButtonDisabledLabelStyle),
  Sounds: @ButtonSounds,
);

@SmallBuyTextButton = TextButton {
  @Anchor = Anchor();
  @Sounds = ();
  @Text = "";
  Style: (
    ...@SmallBuyTextButtonStyle,
    Sounds: (
      ...$Sounds.@ButtonsLight,
      ...@Sounds
    )
  );
  Anchor: (...@Anchor, Height: @SmallButtonHeight);
  Padding: (Horizontal: 16);
  Text: @Text;
};

@SmallTertiaryTextButton = TextButton {
  @Anchor = Anchor();
  @Sounds = ();
  @Text = "";
  Style: (
    ...@SmallTertiaryTextButtonStyle,
    Sounds: (
      ...$Sounds.@ButtonsLight,
      ...@Sounds
    )
  );
  Anchor: (...@Anchor, Height: @SmallButtonHeight);
  Padding: (Horizontal: 16);
  Text: @Text;
};

@SecondaryTextButton = TextButton {
  @Anchor = Anchor();
  @Sounds = ();
  @Text = "";
  Style: (
    ...@SecondaryTextButtonStyle,
    Sounds: (
      ...$Sounds.@ButtonsLight,
      ...@Sounds
    )
  );
  Anchor: (...@Anchor, Height: @DefaultButtonHeight);
  Padding: (Horizontal: @DefaultButtonPadding);
  Text: @Text;
};

@SecondaryButton = Button {
  @Anchor = Anchor();
  @Sounds = ();
  @Width = @DefaultButtonHeight;
  Style: (
    ...@SecondaryButtonStyle,
    Sounds: (
      ...$Sounds.@ButtonsLight,
      ...@Sounds
    )
  );
  Anchor: (...@Anchor, Height: @DefaultButtonHeight, Width: @Width);
};

@TertiaryTextButton = TextButton {
  @Anchor = Anchor();
  @Sounds = ();
  @Text = "";
  Style: (
    ...@TertiaryTextButtonStyle,
    Sounds: (
      ...$Sounds.@ButtonsLight,
      ...@Sounds
    )
  );
  Anchor: (...@Anchor, Height: @DefaultButtonHeight);
  Padding: (Horizontal: @DefaultButtonPadding);
  Text: @Text;
};

@TertiaryButton = Button {
  @Anchor = Anchor();
  @Sounds = ();
  @Width = @DefaultButtonHeight;
  Style: (
    ...@TertiaryButtonStyle,
    Sounds: (
      ...$Sounds.@ButtonsLight,
      ...@Sounds
    )
  );
  Anchor: (...@Anchor, Height: @DefaultButtonHeight, Width: @Width);
};


@DefaultColorPickerStyle = ColorPickerStyle(
  OpacitySelectorBackground: "../Common/ColorPickerOpacitySelectorBackground.png",
  ButtonBackground: "../Common/ColorPickerButton.png",
  ButtonFill: "../Common/ColorPickerFill.png",
  TextFieldDecoration: (
    Default: (
      Background: #000000(0.5)
    )
  ),
  TextFieldPadding: (Left: 7),
  TextFieldHeight: 32
);

@DefaultColorPickerDropdownBoxStyle = ColorPickerDropdownBoxStyle(
  ColorPickerStyle: @DefaultColorPickerStyle,
  Background: (Default: "../Common/ColorPickerDropdownBoxBackground.png"),
  ArrowBackground: (Default: "../Common/ColorPickerDropdownBoxArrow.png"),
  Overlay: (Default: "../Common/ColorPickerDropdownBoxOverlay.png"),
  PanelBackground: (TexturePath: "../Textures/MedievalShop/Patches/DropdownBox.png", Border: 16),
  PanelPadding: (Full: 15),
  PanelOffset: 10,
  ArrowAnchor: (Width: 11, Height: 7, Right: 3, Bottom: 3)
);

@CloseButton = Button {
  Anchor: (Top: -16, Right: -16, Width: 32, Height: 32);

  Style: (
    Default: (Background: "../Textures/MedievalShop/Patches/ContainerCloseButton.png"),
    Hovered: (Background: "../Textures/MedievalShop/Patches/ContainerCloseButtonHovered.png"),
    Pressed: (Background: "../Textures/MedievalShop/Patches/ContainerCloseButtonPressed.png"),
  );
};

@DefaultScrollbarStyle = ScrollbarStyle(
  Spacing: 6,
  Size: 6,
  Background: (TexturePath: "../Textures/MedievalShop/Patches/Scrollbar.png", Border: 3),
  Handle: (TexturePath: "../Textures/MedievalShop/Patches/ScrollbarHandle.png", Border: 3),
  HoveredHandle: (TexturePath: "../Textures/MedievalShop/Patches/ScrollbarHandleHovered.png", Border: 3),
  DraggedHandle: (TexturePath: "../Textures/MedievalShop/Patches/ScrollbarHandleDragged.png", Border: 3)
);

@DefaultExtraSpacingScrollbarStyle = ScrollbarStyle(
  ...@DefaultScrollbarStyle,
  Spacing: 12
);

@TranslucentScrollbarStyle = ScrollbarStyle(
  Spacing: 6,
  Size: 6,
  OnlyVisibleWhenHovered: true,
  Handle: (TexturePath: "../Textures/MedievalShop/Patches/ScrollbarHandle.png", Border: 3)
);

@DefaultPlaceholderScrollbarStyle = ScrollbarStyle(
  Spacing: 12,
  Size: 10
);

@DefaultCheckBoxStyle = CheckBoxStyle(
  Unchecked: (
    DefaultBackground: (Color: #00000000),
    HoveredBackground: (Color: #00000000),
    PressedBackground: (Color: #00000000),
    DisabledBackground: (Color: #424242),
    ChangedSound: (SoundPath: $Sounds.@Untick, Volume: 6)
  ),
  Checked: (
    DefaultBackground: (TexturePath: "../Textures/MedievalShop/CheckBox/Checkmark.png"),
    HoveredBackground: (TexturePath: "../Textures/MedievalShop/CheckBox/Checkmark.png"),
    PressedBackground: (TexturePath: "../Textures/MedievalShop/CheckBox/Checkmark.png"),
    ChangedSound: (SoundPath: $Sounds.@Tick, Volume: 6)
  )
);

@CheckBox = CheckBox {
  Anchor: (Width: 22, Height: 22);
  Background: (TexturePath: "../Textures/MedievalShop/CheckBox/CheckBoxFrame.png", Border: 7);
  Padding: (Full: 4);
  Style: @DefaultCheckBoxStyle;
};

@CheckBoxWithLabel = Group {
  @Checked = false;
  @LabelStyle = ();

  LayoutMode: Left;

  @CheckBox #CheckBox {
    Value: @Checked;
  }


  Label {
    Text: @Text;
    Anchor: (Right: 30, Left: 11);
    Style: (
      ...@DefaultLabelStyle,
      ...@LabelStyle,
      VerticalAlignment: Center
    );
  }
};

@InputBoxBackground = PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/InputBox.png", Border: 16);
@InputBoxHoveredBackground = PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/InputBoxHovered.png", Border: 16);
@InputBoxPressedBackground = PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/InputBoxPressed.png", Border: 16);
@InputBoxSelectedBackground = PatchStyle(TexturePath: "../Textures/MedievalShop/Patches/InputBoxSelected.png", Border: 16);

@DefaultInputFieldStyle = InputFieldStyle();
@DefaultInputFieldPlaceholderStyle = InputFieldStyle(TextColor: #6e7da1);

@TextField = TextField {
  @Anchor = ();

  Style: @DefaultInputFieldStyle;
  PlaceholderStyle: @DefaultInputFieldPlaceholderStyle;
  Background: @InputBoxBackground;
  Anchor: (...@Anchor, Height: 38);
  Padding: (Horizontal: 10);
};

@NumberField = NumberField {
  @Anchor = ();

  Style: @DefaultInputFieldStyle;
  PlaceholderStyle: @DefaultInputFieldPlaceholderStyle;
  Background: @InputBoxBackground;
  Anchor: (...@Anchor, Height: 38);
  Padding: (Horizontal: 10);
};

@MultilineTextField = MultilineTextField {
  @Anchor = ();

  Style: @DefaultInputFieldStyle;
  PlaceholderStyle: @DefaultInputFieldPlaceholderStyle;
  Background: @InputBoxBackground;
  Anchor: (...@Anchor);
  Padding: (Full: 10);
  ScrollbarStyle: @DefaultScrollbarStyle;
};

@DefaultDropdownBoxLabelStyle = LabelStyle(TextColor: #c9b181, RenderUppercase: true, VerticalAlignment: Center, FontSize: 13);
@DefaultDropdownBoxEntryLabelStyle = LabelStyle(...@DefaultDropdownBoxLabelStyle, TextColor: #e9d4a4);

@DefaultDropdownBoxStyle = DropdownBoxStyle(
  DefaultBackground: (TexturePath: "../Textures/MedievalShop/Patches/Dropdown.png", Border: 16),
  HoveredBackground: (TexturePath: "../Textures/MedievalShop/Patches/DropdownHovered.png", Border: 16),
  PressedBackground: (TexturePath: "../Textures/MedievalShop/Patches/DropdownPressed.png", Border: 16),
  DefaultArrowTexturePath: "../Textures/MedievalShop/Patches/DropdownCaret.png",
  HoveredArrowTexturePath: "../Textures/MedievalShop/Patches/DropdownCaret.png",
  PressedArrowTexturePath: "../Textures/MedievalShop/Patches/DropdownPressedCaret.png",
  ArrowWidth: 13,
  ArrowHeight: 18,
  LabelStyle: @DefaultDropdownBoxLabelStyle,
  EntryLabelStyle: @DefaultDropdownBoxEntryLabelStyle,
  NoItemsLabelStyle: (...@DefaultDropdownBoxEntryLabelStyle, TextColor: #e9d4a4(0.5)),
  SelectedEntryLabelStyle: (...@DefaultDropdownBoxEntryLabelStyle, RenderBold: true),
  HorizontalPadding: 8,
  PanelScrollbarStyle: @DefaultScrollbarStyle,
  PanelBackground: (TexturePath: "../Textures/MedievalShop/Patches/DropdownBox.png", Border: 16),
  PanelPadding: 6,
  PanelAlign: Right,
  PanelOffset: 7,
  EntryHeight: 31,
  EntriesInViewport: 10,
  HorizontalEntryPadding: 7,
  HoveredEntryBackground: (Color: #2a1d10),
  PressedEntryBackground: (Color: #3a2a18),
  Sounds: $Sounds.@DropdownBox,
  EntrySounds: $Sounds.@ButtonsLight,
  FocusOutlineSize: 1,
  FocusOutlineColor: #ffffff(0.4)
);

@DropdownBoxHeight = 32;

@DropdownBox = DropdownBox {
  @Anchor = (Width: 330, Height: @DropdownBoxHeight);

  Anchor: (...@Anchor);
  Style: @DefaultDropdownBoxStyle;
};

